# ========================================
# UPA Configuration Example
# ========================================
# Copy this file to .env and fill in your API keys

# Default provider (dashscope | cloudflare)
UPA_PROVIDER=cloudflare

# Web Search (true | false) - enables fact-checking via DuckDuckGo
UPA_WEB_SEARCH=true

# ========================================
# DashScope Configuration (Aliyun Qwen)
# ========================================
DASHSCOPE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.5-plus

# ========================================
# Cloudflare Gateway + Grok Configuration
# ========================================
CLOUDFLARE_URL=https://gateway.ai.cloudflare.com/v1/632ba9b9506a87e7fe1d5f7e7db78d57/gemini/compat
CLOUDFLARE_API_KEY=
CLOUDFLARE_MODEL=grok/grok-4-1-fast-non-reasoning
