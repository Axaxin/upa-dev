# ========================================
# UPA Configuration Example
# ========================================
# Copy this file to .env and fill in your API keys
#
# All provider URLs and default models are pre-configured.
# You only need to set API_KEY (and optionally override MODEL/URL).

# ========================================
# Active Configuration
# ========================================
# Select which provider to use by default (for Coder)
UPA_PROVIDER=cloudflare

# Override model for specific purposes (optional)
# If not set, uses provider's default model
UPA_MODEL=grok/grok-code-fast-1

# ========================================
# Cross-Provider Configuration (Optional)
# ========================================
# You can use different providers for different components!
#
# Example setup:
# - Coder: dashscope (kimi-k2.5) - good at code generation
# - Planner: openai (o3-mini) - good at reasoning
# - Sub-Agent: dashscope (qwen-turbo) - fast and cheap for semantic tasks

# Planner: Use a different provider/model for task planning
# If not set, uses same provider/model as coder
UPA_PLANNER_PROVIDER=dashscope
UPA_PLANNER_MODEL=kimi-k2.5

# Sub-Agent: Use a different provider/model for semantic tasks
# If not set, uses same provider/model as coder
UPA_SUB_AGENT_PROVIDER=dashscope
UPA_SUB_AGENT_MODEL=kimi-k2.5

# Feature flags
UPA_WEB_SEARCH=true
UPA_PLANNER=true

# ========================================
# Web Search: Tavily API
# ========================================
# Free tier: 1000 searches/month
# Sign up: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# ========================================
# Provider: DashScope (阿里云 Qwen 系列)
# ========================================
# Default model: kimi-k2.5
# Models: qwen-plus, qwen-turbo, qwen-max, kimi-k2.5, etc.
# Note: Use https://coding.dashscope.aliyuncs.com/v1 for kimi-k2.5
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=kimi-k2.5

# ========================================
# Provider: Cloudflare Gateway (Grok 系列)
# ========================================
# Default model: grok/grok-code-fast-1
# Models: grok/grok-code-fast-1, grok/grok-4-1-fast-non-reasoning, etc.
# Replace ACCOUNT_ID with your Cloudflare account ID
CLOUDFLARE_API_KEY=your-cloudflare-bearer-token
# CLOUDFLARE_URL=https://gateway.ai.cloudflare.com/v1/ACCOUNT_ID/gemini/compat
# CLOUDFLARE_MODEL=grok/grok-code-fast-1

# ========================================
# Provider: OpenAI (原生)
# ========================================
# Default model: gpt-4o
# Models: gpt-4o, gpt-4o-mini, o3-mini, etc.
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ========================================
# Provider: Anthropic (通过兼容层)
# ========================================
# Default model: claude-sonnet-4-5-20251022
# Models: claude-sonnet-4-5-20251022, claude-opus-4-5-20251101, etc.
# Works with: Anthropic direct, OpenRouter, etc.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# ANTHROPIC_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-sonnet-4-5-20251022

# ========================================
# Provider: Custom (任意 OpenAI 兼容端点)
# ========================================
# Use this for any other OpenAI-compatible API
# CUSTOM_API_KEY=your-api-key
# CUSTOM_URL=https://your-custom-api.com/v1
# CUSTOM_MODEL=your-model-name

# ========================================
# Advanced Settings (Optional)
# ========================================
UPA_PLANNER_TIMEOUT=5.0
UPA_SUB_AGENT_DEPTH=3
UPA_SUB_AGENT_TIMEOUT=60
UPA_MAX_SECURITY_RETRIES=3
UPA_MAX_EXECUTION_RETRIES=3
